# ---------- Database (Prisma + PostgreSQL) ----------
# Local docker-compose default; override for hosted Postgres.
DATABASE_URL="postgresql://workshop:workshop@localhost:5432/workshop_buddy?schema=public"

# ---------- Redis (cache + BullMQ) ----------
# BullMQ / ioredis need a raw TCP Redis URL (docker-compose provides one):
REDIS_URL="redis://localhost:6379"
# Upstash REST client (cache helpers). Leave blank to use the local ioredis fallback.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---------- Auth (NextAuth) ----------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
# Single-user dev: credentials the built-in Credentials provider accepts.
AUTH_USER_EMAIL="maker@workshop.local"
AUTH_USER_PASSWORD="workshop"
# API routes fall back to this user when no session is present (dev convenience).
DEV_USER_EMAIL="maker@workshop.local"

# ---------- Pricing engine: proxy / scraping ----------
# Set a key to route fetches through a residential proxy. If empty, the fetcher
# falls back to a direct fetch and logs a TODO (works without paid services).
SCRAPER_PROVIDER="" # "scraperapi" | "brightdata" | "" (direct)
SCRAPERAPI_KEY=""
BRIGHTDATA_URL="" # e.g. http://user:pass@brd.superproxy.io:22225

# ---------- Optional official retailer APIs (preferred over scraping) ----------
AMAZON_PAAPI_KEY=""
AMAZON_PAAPI_SECRET=""
AMAZON_PARTNER_TAG=""
WALMART_API_KEY=""
BESTBUY_API_KEY=""
